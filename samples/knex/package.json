{
  "name": "swaggiffy-sample-knex",
  "version": "1.0.0",
  "description": "Swaggiffy sample: Inventory API using Knex + PostgreSQL",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/app.ts",
    "dev": "nodemon --ignore '**/swagger.json' --exec \"ts-node -r tsconfig-paths/register src/app.ts\"",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.8.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
