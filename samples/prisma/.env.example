PORT=3004

# SQLite (default — no server needed, works out of the box)
DATABASE_URL=file:./dev.db

# PostgreSQL (uncomment and update to use PostgreSQL instead)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swaggiffy_cms
# Then also change the datasource provider in prisma/schema.prisma to "postgresql"

JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h
